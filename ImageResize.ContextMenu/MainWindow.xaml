<Window x:Class="ImageResize.ContextMenu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resize Images"
        Width="560"
        Height="680"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}">

    <!-- ApplicationCommands.Help defaults to F1 -->
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Help" Executed="Help_Executed" />
    </Window.CommandBindings>

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.75"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SubtleIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24,16,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header row: file info + About button -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock x:Name="FileCountText"
                           FontSize="16"
                           FontWeight="SemiBold"
                           AutomationProperties.Name="Selected file count"/>
                <TextBlock x:Name="OriginalDimensionsText"
                           FontSize="13"
                           Opacity="0.7"
                           Margin="0,4,0,0"
                           AutomationProperties.Name="Original image dimensions"/>
            </StackPanel>
            <Button Grid.Column="1"
                    x:Name="AboutButton"
                    Style="{StaticResource SubtleIconButton}"
                    Content="?"
                    Width="28"
                    Height="28"
                    ToolTip="About (F1)"
                    AutomationProperties.Name="About"
                    Click="AboutButton_Click"/>
        </Grid>

        <!-- Drop hint -->
        <Border Grid.Row="1"
                x:Name="DropHintBorder"
                Margin="0,0,0,16"
                Padding="10,6"
                CornerRadius="4"
                BorderThickness="1"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <TextBlock Text="Tip: drag additional images onto this window to queue them."
                       FontSize="11"
                       Opacity="0.75"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Percentage Slider -->
        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock x:Name="PercentageLabel" Text="Size Percentage" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="PercentageSlider"
                        Minimum="10"
                        Maximum="200"
                        Value="100"
                        TickFrequency="25"
                        TickPlacement="BottomRight"
                        IsSnapToTickEnabled="False"
                        TabIndex="1"
                        AutomationProperties.Name="Size percentage"
                        ValueChanged="PercentageSlider_ValueChanged"/>
                <TextBlock Grid.Column="1"
                           x:Name="PercentageText"
                           Text="100%"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           MinWidth="60"
                           FontWeight="SemiBold"/>
            </Grid>
        </StackPanel>

        <!-- Dimensions -->
        <StackPanel x:Name="DimensionsPanel" Grid.Row="3" Margin="0,0,0,20">
            <TextBlock Text="Target Dimensions" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Width (px)" Margin="0,0,0,4"/>
                    <TextBox x:Name="WidthBox"
                             TabIndex="2"
                             AutomationProperties.Name="Target width in pixels"
                             TextChanged="DimensionBox_TextChanged"
                             PreviewTextInput="NumberValidationTextBox"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                          Text="×"
                          FontSize="16"
                          VerticalAlignment="Center"
                          Margin="16,20,16,0"
                          Opacity="0.55"/>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Height (px)" Margin="0,0,0,4"/>
                    <TextBox x:Name="HeightBox"
                             TabIndex="3"
                             AutomationProperties.Name="Target height in pixels"
                             TextChanged="DimensionBox_TextChanged"
                             PreviewTextInput="NumberValidationTextBox"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Quality Slider -->
        <StackPanel Grid.Row="4" Margin="0,0,0,20">
            <TextBlock Text="Quality" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="QualitySlider"
                        Minimum="10"
                        Maximum="100"
                        Value="99"
                        TickFrequency="10"
                        TickPlacement="BottomRight"
                        TabIndex="4"
                        AutomationProperties.Name="Output quality"
                        ValueChanged="QualitySlider_ValueChanged"/>
                <TextBlock Grid.Column="1"
                           x:Name="QualityText"
                           Text="99"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           MinWidth="40"
                           FontWeight="SemiBold"/>
            </Grid>
        </StackPanel>

        <!-- Options -->
        <StackPanel Grid.Row="5" Margin="0,0,0,20">
            <CheckBox x:Name="OverwriteCheckBox"
                      Content="Overwrite existing files"
                      IsChecked="True"
                      TabIndex="5"
                      AutomationProperties.Name="Overwrite existing files"/>
            <TextBlock Text="If unchecked, resized files will be saved with ' (1)' appended to the filename."
                       TextWrapping="Wrap"
                       Opacity="0.65"
                       FontSize="11"
                       Margin="25,6,0,0"/>
        </StackPanel>

        <!-- Progress -->
        <StackPanel Grid.Row="6" Margin="0,0,0,16" x:Name="ProgressPanel" Visibility="Collapsed">
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="ProgressText"
                           Text="Processing..."
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1"
                           x:Name="ProgressEtaText"
                           Margin="12,0,0,0"
                           Opacity="0.7"
                           FontSize="12"/>
            </Grid>
            <ProgressBar x:Name="ProgressBar" Height="8" Minimum="0" Maximum="100"/>
        </StackPanel>

        <!-- Result summary -->
        <Border Grid.Row="7"
                x:Name="ErrorBorder"
                Background="{DynamicResource {x:Static SystemColors.InfoBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                Padding="12"
                Margin="0,0,0,16"
                Visibility="Collapsed"
                CornerRadius="4">
            <StackPanel>
                <TextBlock x:Name="ErrorHeading" Text="Error" FontWeight="Bold"/>
                <TextBlock x:Name="ErrorText" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="104"
                    Height="34"
                    Margin="0,0,12,0"
                    TabIndex="7"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
            <Button x:Name="ResizeButton"
                    Content="Resize"
                    Width="104"
                    Height="34"
                    TabIndex="6"
                    IsDefault="True"
                    Style="{StaticResource PrimaryButton}"
                    Click="ResizeButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
