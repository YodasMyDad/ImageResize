<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ImageResize.ContextMenu.MainWindow"
        Title="Resize Images"
        Width="560"
        Height="680"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        DragDrop.AllowDrop="True">

    <Grid Margin="24,16,24,20"
          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto">

        <!-- Header row: file info + About button -->
        <Grid Grid.Row="0" Margin="0,0,0,16" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
                <TextBlock x:Name="FileCountText"
                           FontSize="16"
                           FontWeight="SemiBold"
                           AutomationProperties.Name="Selected file count"/>
                <TextBlock x:Name="OriginalDimensionsText"
                           FontSize="13"
                           Opacity="0.7"
                           Margin="0,4,0,0"
                           AutomationProperties.Name="Original image dimensions"/>
            </StackPanel>
            <Button Grid.Column="1"
                    x:Name="AboutButton"
                    Content="?"
                    Width="32"
                    Height="32"
                    Padding="0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    CornerRadius="16"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    ToolTip.Tip="About (F1)"
                    AutomationProperties.Name="About"
                    Click="AboutButton_Click"/>
        </Grid>

        <!-- Drop zone -->
        <Grid Grid.Row="1" x:Name="DropZone" Margin="0,0,0,16" Height="56">
            <Rectangle x:Name="DropZoneBorder"
                       Stroke="#66888888"
                       StrokeThickness="1.5"
                       StrokeDashArray="4,3"
                       RadiusX="6"
                       RadiusY="6"/>
            <TextBlock Text="Drop additional images here"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <!-- Percentage Slider -->
        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock x:Name="PercentageLabel" Text="Size Percentage" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid ColumnDefinitions="*,Auto">
                <Slider x:Name="PercentageSlider"
                        Minimum="10"
                        Maximum="200"
                        Value="100"
                        TickFrequency="25"
                        TickPlacement="BottomRight"
                        IsSnapToTickEnabled="False"
                        TabIndex="1"
                        AutomationProperties.Name="Size percentage"
                        ValueChanged="PercentageSlider_ValueChanged"/>
                <TextBlock Grid.Column="1"
                           x:Name="PercentageText"
                           Text="100%"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           MinWidth="60"
                           FontWeight="SemiBold"/>
            </Grid>
        </StackPanel>

        <!-- Dimensions -->
        <StackPanel x:Name="DimensionsPanel" Grid.Row="3" Margin="0,0,0,20">
            <TextBlock Text="Target Dimensions" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Grid ColumnDefinitions="*,Auto,*">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Width (px)" Margin="0,0,0,4"/>
                    <TextBox x:Name="WidthBox"
                             TabIndex="2"
                             AutomationProperties.Name="Target width in pixels"
                             TextChanged="DimensionBox_TextChanged"
                             TextInput="NumberValidationTextBox"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                          Text="×"
                          FontSize="16"
                          VerticalAlignment="Center"
                          Margin="16,20,16,0"
                          Opacity="0.55"/>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Height (px)" Margin="0,0,0,4"/>
                    <TextBox x:Name="HeightBox"
                             TabIndex="3"
                             AutomationProperties.Name="Target height in pixels"
                             TextChanged="DimensionBox_TextChanged"
                             TextInput="NumberValidationTextBox"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Quality Slider -->
        <StackPanel Grid.Row="4" Margin="0,0,0,20">
            <TextBlock Text="Quality" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid ColumnDefinitions="*,Auto">
                <Slider x:Name="QualitySlider"
                        Minimum="10"
                        Maximum="100"
                        Value="99"
                        TickFrequency="10"
                        TickPlacement="BottomRight"
                        TabIndex="4"
                        AutomationProperties.Name="Output quality"
                        ValueChanged="QualitySlider_ValueChanged"/>
                <TextBlock Grid.Column="1"
                           x:Name="QualityText"
                           Text="99"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           MinWidth="40"
                           FontWeight="SemiBold"/>
            </Grid>
        </StackPanel>

        <!-- Options -->
        <StackPanel Grid.Row="5" Margin="0,0,0,20">
            <CheckBox x:Name="OverwriteCheckBox"
                      Content="Overwrite existing files"
                      IsChecked="True"
                      TabIndex="5"
                      AutomationProperties.Name="Overwrite existing files"/>
            <TextBlock Text="If unchecked, resized files will be saved with ' (1)' appended to the filename."
                       TextWrapping="Wrap"
                       Opacity="0.65"
                       FontSize="11"
                       Margin="25,6,0,0"/>
        </StackPanel>

        <!-- Progress -->
        <StackPanel Grid.Row="6" Margin="0,0,0,16" x:Name="ProgressPanel" IsVisible="False">
            <Grid Margin="0,0,0,6" ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           x:Name="ProgressText"
                           Text="Processing..."
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1"
                           x:Name="ProgressEtaText"
                           Margin="12,0,0,0"
                           Opacity="0.7"
                           FontSize="12"/>
            </Grid>
            <ProgressBar x:Name="ProgressBar" Height="8" Minimum="0" Maximum="100"/>
        </StackPanel>

        <!-- Result summary. Hardcoded colours: theme resources for "caution" are
             unreliable in Avalonia 11.2.5 Fluent (see drop-zone rendering bug discovered
             earlier). Amber at low opacity reads well in both Light and Dark. -->
        <Border Grid.Row="7"
                x:Name="ErrorBorder"
                Background="#22F59E0B"
                BorderBrush="#66F59E0B"
                BorderThickness="1"
                Padding="12"
                Margin="0,0,0,16"
                IsVisible="False"
                CornerRadius="4">
            <StackPanel>
                <TextBlock x:Name="ErrorHeading" Text="Error" FontWeight="SemiBold"/>
                <TextBlock x:Name="ErrorText" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="104"
                    Height="34"
                    Margin="0,0,12,0"
                    TabIndex="7"
                    IsCancel="True"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="CancelButton_Click"/>
            <Button x:Name="ResizeButton"
                    Content="Resize"
                    Width="104"
                    Height="34"
                    TabIndex="6"
                    IsDefault="True"
                    Classes="accent"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="ResizeButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
