<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ImageResize.ContextMenu.AboutWindow"
        Title="About Resize Images"
        Width="460"
        Height="340"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24" RowDefinitions="Auto,Auto,Auto,*,Auto">

        <TextBlock Grid.Row="0"
                   Text="Resize Images"
                   FontSize="22"
                   FontWeight="SemiBold" />

        <TextBlock Grid.Row="1"
                   x:Name="AppVersionText"
                   Margin="0,4,0,0"
                   FontSize="13"
                   Opacity="0.8" />

        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <TextBlock x:Name="CoreVersionText" FontSize="12" Opacity="0.75" />
            <TextBlock x:Name="SkiaVersionText" FontSize="12" Opacity="0.75" Margin="0,4,0,0" />
            <TextBlock x:Name="RuntimeVersionText" FontSize="12" Opacity="0.75" Margin="0,4,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,20,0,0">
            <TextBlock TextWrapping="Wrap"
                       FontSize="12"
                       Opacity="0.75"
                       Text="Minimal, cross-platform image-resize middleware for ASP.NET Core, plus a desktop companion app. Distributed under the MIT License." />
            <HyperlinkButton x:Name="GitHubLink"
                             Margin="0,8,0,0"
                             Padding="0"
                             FontSize="12"
                             HorizontalAlignment="Left"
                             Content="github.com/YodasMyDad/ImageResize"
                             NavigateUri="https://github.com/YodasMyDad/ImageResize"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CloseButton"
                    Content="Close"
                    Width="96"
                    Height="32"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    IsDefault="True"
                    IsCancel="True"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
